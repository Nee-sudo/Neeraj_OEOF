# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Database Configuration (App Service / Local)
# MongoDB: Connection URI string for the database
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/oneearth?retryWrites=true&w=majority
DATABASE_URL=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/oneearth?retryWrites=true&w=majority

# Web Application Security secrets for JWT Token handling
JWT_SECRET=super_secret_one_earth_jwt_signing_key_change_me_in_production
JWT_REFRESH_SECRET=super_secret_one_earth_jwt_refresh_signing_key_change_me_in_production

# Backend Service PORT configuration
PORT=4000

